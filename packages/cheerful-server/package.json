{
  "name": "cheerful-server",
  "version": "0.2.0",
  "description": "Backend server for Cheerful encrypted sync",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "shx rm -rf dist && npx tsc --noEmit && pkgroll",
    "test": "$npm_execpath run build && vitest run",
    "dev": "tsx sources/main.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@cheerful/wire": "^0.1.0",
    "@prisma/client": "^6.9.0",
    "fastify": "^5.6.2",
    "fastify-type-provider-zod": "4.0.2",
    "@fastify/cors": "^10.0.2",
    "socket.io": "^4.8.1",
    "expo-server-sdk": "^3.15.0",
    "tweetnacl": "^1.0.3",
    "zod": "3.25.76",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.13.2"
  },
  "devDependencies": {
    "@types/node": ">=20",
    "@types/jsonwebtoken": "^9.0.9",
    "prisma": "^6.9.0",
    "pkgroll": "^2.14.2",
    "shx": "^0.3.3",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "yarn@1.22.22"
}
